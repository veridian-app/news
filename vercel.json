{
  "crons": [
    {
      "path": "/api/cron/generate-covers",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/curate-cafe",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/generate-polls",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/analyze-boe",
      "schedule": "0 9 * * 1-5"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!api/.*).*)",
      "destination": "/index.html"
    }
  ]
}